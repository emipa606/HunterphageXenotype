  <MeleeWeapon_Hunterphage_ShadowDagger.tools.handle.label>manche</MeleeWeapon_Hunterphage_ShadowDagger.tools.handle.label>
  <MeleeWeapon_Hunterphage_ShadowDagger.tools.point.label>pointe</MeleeWeapon_Hunterphage_ShadowDagger.tools.point.label>
  <MeleeWeapon_Hunterphage_ShadowDagger.tools.blade_edge.label>tranchant de la lame</MeleeWeapon_Hunterphage_ShadowDagger.tools.blade_edge.label>
