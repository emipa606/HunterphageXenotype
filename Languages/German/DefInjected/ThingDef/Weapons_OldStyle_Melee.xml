  <MeleeWeapon_Hunterphage_ShortSword.label>Kurzschwert</MeleeWeapon_Hunterphage_ShortSword.label>
  <!-- EN: A well rounded melee weapon, perfect for stabbing and cutting. -->
  <MeleeWeapon_Hunterphage_ShortSword.description>Eine vielseitige Nahkampfwaffe, perfekt zum Stechen und Schneiden.</MeleeWeapon_Hunterphage_ShortSword.description>
